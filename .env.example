# DentaLand - Environment Configuration Template
# Copy this file to '.env' and fill in your values for production.

# Toggle to use a live backend database API instead of local mockup latency services
VITE_USE_REAL_API=false

# Root endpoint URL of the DentaLand backend
VITE_API_BASE_URL=https://api.example.com/v1

# Google Analytics 4 Measurement / Tracking ID
VITE_GA_MEASUREMENT_ID=YOUR_GA_ID
